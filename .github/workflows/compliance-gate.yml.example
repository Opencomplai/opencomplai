# compliance-gate.yml.example
#
# Copy this file to .github/workflows/compliance-gate.yml in YOUR AI system
# repository to add EU AI Act compliance gating to every pull request.
#
# Prerequisites:
#   1. A running OpenComplAI instance (self-hosted or managed Pro)
#   2. Set OPENCOMPLAI_GATEWAY_URL in your repository secrets
#   3. A manifest.yaml in your repo root (see examples/sample-system/)

name: EU AI Act Compliance Gate

on:
  push:
    branches: [main, master]
  pull_request:
    branches: [main, master]

jobs:
  compliance-check:
    name: EU AI Act compliance check
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v5

      # -----------------------------------------------------------------------
      # Option A: Use the OpenComplAI compliance action (recommended)
      # -----------------------------------------------------------------------
      # - name: Run OpenComplAI compliance check
      #   uses: opencomplai/compliance-action@v1
      #   with:
      #     gateway-url: ${{ secrets.OPENCOMPLAI_GATEWAY_URL }}
      #     manifest: manifest.yaml

      # -----------------------------------------------------------------------
      # Option B: Use the shell script directly (no Action dependency)
      # -----------------------------------------------------------------------
      - name: Run compliance check script
        env:
          OPENCOMPLAI_GATEWAY_URL: ${{ secrets.OPENCOMPLAI_GATEWAY_URL }}
          GITHUB_SHA: ${{ github.sha }}
        run: |
          chmod +x run-compliance-check.sh
          ./run-compliance-check.sh

      # -----------------------------------------------------------------------
      # Upload SVG badge as a workflow artifact (optional)
      # -----------------------------------------------------------------------
      - name: Fetch compliance badge SVG
        if: success()
        env:
          OPENCOMPLAI_GATEWAY_URL: ${{ secrets.OPENCOMPLAI_GATEWAY_URL }}
        run: |
          SYSTEM_ID=$(python3 -c "
          import yaml, sys
          m = yaml.safe_load(open('manifest.yaml'))
          print(m['system']['id'])
          ")
          BUNDLE_CHECKSUM=$(python3 -c "
          import hashlib
          data = open('manifest.yaml', 'rb').read()
          print('sha256:' + hashlib.sha256(data).hexdigest())
          ")
          BADGE_ID=$(python3 -c "
          import hashlib
          raw = '${SYSTEM_ID}:${BUNDLE_CHECKSUM}'.encode()
          print('sha256:' + hashlib.sha256(raw).hexdigest())
          ")
          curl -sf "${OPENCOMPLAI_GATEWAY_URL}/v1/pro/badges/${BADGE_ID}/svg" \
            -o compliance-badge.svg || echo "Badge SVG fetch skipped"

      - name: Upload compliance badge
        if: success()
        uses: actions/upload-artifact@v4
        with:
          name: compliance-badge
          path: compliance-badge.svg
          if-no-files-found: ignore

  # ---------------------------------------------------------------------------
  # Ledger integrity check (optional but recommended for audits)
  # ---------------------------------------------------------------------------
  ledger-verify:
    name: Verify evidence ledger integrity
    runs-on: ubuntu-latest
    if: github.ref == 'refs/heads/main' || github.ref == 'refs/heads/master'

    steps:
      - name: Checkout repository
        uses: actions/checkout@v5

      - name: Download ledger verifier
        run: |
          curl -sSL \
            https://raw.githubusercontent.com/opencomplai/opencomplai/main/tools/verify-ledger/verify_ledger.py \
            -o verify_ledger.py

      - name: Run ledger integrity check
        env:
          OPENCOMPLAI_GATEWAY_URL: ${{ secrets.OPENCOMPLAI_GATEWAY_URL }}
        run: |
          python3 verify_ledger.py --gateway-url "${OPENCOMPLAI_GATEWAY_URL}"
