      "id": 7,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "sum(opencomplai_dossier_generated_total) or vector(0)",
          "refId": "A"
        }
      ],
      "title": "Dossiers generated (total)",
