    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Rate of all audit events written to the ledger (ISO 27001 A.8.16 / SOC 2 CC7.2)",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 9,
      "targets": [
        {
          "expr": "sum(rate(opencomplai_compliance_check_completed_total[5m]))",
