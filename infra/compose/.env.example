# =============================================================================
# Opencomplai Docker Compose — environment variables
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# =============================================================================

# --- PostgreSQL (required) ---
POSTGRES_DB=opencomplai
POSTGRES_USER=opencomplai
POSTGRES_PASSWORD=changeme_use_a_strong_password

# --- Gateway API ---
# Port exposed to the host machine. Default: 8080.
GATEWAY_PORT=8080

# REQUIRED for any non-dev deployment. Shared secret enforced on every
# non-/health request via the x-api-key header. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# If you set OPENCOMPLAI_AUTH_DISABLED=1 instead, the gateway will start
# without auth and log a warning on every boot. Never do this in production.
OPENCOMPLAI_API_KEY=
# OPENCOMPLAI_AUTH_DISABLED=1

# --- OIDC JWT auth (multi-user / SaaS mode) ---
# Set OIDC_JWKS_URI to enable JWT Bearer auth instead of the shared API key.
# When set, OPENCOMPLAI_API_KEY is ignored and all requests must carry a valid Bearer JWT.
# Example: OIDC_JWKS_URI=https://your-idp.example.com/.well-known/jwks.json
# See docs/deployment/authentication.md for when to use each mode.
# OIDC_JWKS_URI=

# --- Egress Proxy ---
# Comma-separated list of allowed outbound destinations for metadata sync.
# Leave empty to disable all outbound traffic (fully air-gapped mode).
# Example: https://dashboard.opencomplai.org
EGRESS_ALLOWED_DESTINATIONS=

# --- Signing ---
# Path to the local signing key used to sign status artifacts and dossiers.
# Leave empty for unsigned OSS mode (quickstart default).
# LOCAL_SIGNING_KEY_PATH=/data/keys/signing.key

# --- Observability ---
# Host ports for Prometheus and Grafana. Defaults: 9090 and 3001.
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3001

# OpenTelemetry tracer export. Points to the otel-collector service in docker-compose.yml.
# Required for ISO 27001 A.8.16 / SOC 2 CC7.2 / NIST DE.CM compliance.
# Comment out to disable trace export (Prometheus metrics are still exposed via /metrics).
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=opencomplai

# --- Demo data (used by scripts/seed_demo.py and scripts/reset_demo.py) ---
# Hardcoded API key accepted by the gateway in demo/local mode.
# The gateway will validate X-Api-Key against this value when auth is enabled.
DEMO_TENANT_API_KEY=demo-api-key-local
# Base URLs the seeder scripts target (defaults match the compose stack).
DEMO_GATEWAY_URL=http://localhost:8080
DEMO_VAULT_URL=http://localhost:8002
